generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CASHIER
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
}

model ShopSettings {
  id                 String   @id @default(cuid())
  shopName           String
  address            String
  phone              String
  email              String?
  logoUrl            String?
  returnPolicyDays   Int      @default(7)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

model Customer {
  phoneNumber    String    @id
  name           String
  email          String?
  joinedDate     DateTime  @default(now())
  totalPoints    Int       @default(0)
  membershipTier String    @default("SILVER")
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions Transaction[]
  pointHistory CustomerPoint[]
  refunds      Refund[]

  @@index([totalPoints])
  @@index([membershipTier])
  @@index([name])
}

model CustomerPoint {
  id            String       @id @default(cuid())
  customerPhone String
  customer      Customer     @relation(fields: [customerPhone], references: [phoneNumber])
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  pointsChange  Int
  reason        String
  balanceAfter  Int
  createdAt     DateTime     @default(now())

  @@index([customerPhone])
  @@index([createdAt])
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  phoneNumber String    @unique
  joinedDate  DateTime  @default(now())
  notes       String?   @db.Text
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stocks          Stock[]
  supplierBills   SupplierBill[]
  supplierReturns SupplierReturn[]
  creditNotes     SupplierCreditNote[]

  @@index([phoneNumber])
  @@index([name])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id              String    @id @default(cuid())
  name            String
  description     String?   @db.Text
  imageUrl        String?
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  primaryUnit     String
  minStockAlert   Int?      @default(5)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stocks           Stock[]
  unitConversions  ProductUnitConversion[]
  transactionItems TransactionItem[]
  supplierReturns  SupplierReturn[]

  @@index([categoryId])
  @@index([isActive])
  @@index([name])
}

model ProductUnitConversion {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitName         String
  conversionFactor Decimal  @db.Decimal(10, 3)
  createdAt        DateTime @default(now())

  @@unique([productId, unitName])
  @@index([productId])
}

// ==========================================
// SUPPLIER BILL SYSTEM (new)
// ==========================================
// A SupplierBill represents one delivery/invoice from a supplier.
// It groups one or more Stock entries (products received in that delivery).
// Payment is tracked at the bill level, not per-stock.

model SupplierBill {
  id         String   @id @default(cuid())
  billNumber String   @unique  // e.g. SB-00001

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Supplier's own invoice reference (optional, for cross-checking)
  supplierInvoiceRef String?

  // Totals are denormalized for fast reads; recomputed on item change
  totalCost   Decimal @db.Decimal(10, 2)
  amountPaid  Decimal @default(0) @db.Decimal(10, 2)

  // UNPAID | PARTIAL | PAID
  paymentStatus String @default("UNPAID")

  notes     String?   @db.Text
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stocks   Stock[]              // all stock entries in this bill
  payments SupplierBillPayment[]

  @@index([supplierId])
  @@index([paymentStatus])
  @@index([createdAt])
}

model SupplierBillPayment {
  id           String       @id @default(cuid())
  billId       String
  bill         SupplierBill @relation(fields: [billId], references: [id])
  supplierId   String

  amountPaid    Decimal @db.Decimal(10, 2)
  paymentMethod String  // CASH | BANK_TRANSFER | CHECK | CREDIT_NOTE | DEBT_OFFSET
  paymentDate   DateTime @default(now())
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([billId])
  @@index([supplierId])
  @@index([paymentDate])
}

model Stock {
  id        String @id @default(cuid())
  grnNumber String @unique
  externalBarcode String?

  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Optional link to a SupplierBill (null = standalone stock added without a bill)
  supplierBillId String?
  supplierBill   SupplierBill? @relation(fields: [supplierBillId], references: [id])

  quantityAdded     Decimal @db.Decimal(10, 2)
  quantityRemaining Decimal @db.Decimal(10, 2)
  measuringUnit     String

  buyingPricePerUnit  Decimal @db.Decimal(10, 2)
  sellingPricePerUnit Decimal @db.Decimal(10, 2)

  suppliedDate DateTime @default(now())

  // --- Legacy payment fields (kept for standalone stocks not linked to a bill) ---
  // When a stock IS linked to a SupplierBill, these mirror the bill's proportional values
  // and are kept for backward compat with existing views/queries.
  paymentStatus String  @default("UNPAID")
  amountPaid    Decimal @default(0) @db.Decimal(10, 2)
  totalCost     Decimal @db.Decimal(10, 2)

  notes     String?   @db.Text
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // NEW: Dual-unit selling configuration
  canBeSplit        Boolean   @default(false)
  splitUnit         String?   // e.g. 'YARDS', 'PIECES', 'GRAMS'
  unitsPerWhole     Decimal?  @db.Decimal(10, 4)  // e.g. 10.0000 yards per roll
  splitSellingPrice Decimal?  @db.Decimal(10, 2)  // e.g. 20.00 per yard

  payments         StockSupplierPayment[]  // kept for standalone stock payments
  supplierReturns  SupplierReturn[]
  transactionItems TransactionItem[]
  creditNoteUsages CreditNoteUsage[]

  @@index([productId])
  @@index([supplierId])
  @@index([supplierBillId])
  @@index([isActive])
  @@index([quantityRemaining])
  @@index([suppliedDate])
  @@index([paymentStatus])
  @@index([productId, isActive, quantityRemaining, suppliedDate])
  // Merge lookup index: find existing mergeable stock
  @@index([productId, supplierId, buyingPricePerUnit, sellingPricePerUnit, isActive])
}

model StockSupplierPayment {
  id            String   @id @default(cuid())
  stockId       String
  stock         Stock    @relation(fields: [stockId], references: [id])
  supplierId    String
  amountPaid    Decimal  @db.Decimal(10, 2)
  paymentMethod String
  paymentDate   DateTime @default(now())
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([stockId])
  @@index([supplierId])
  @@index([paymentDate])
}

model SupplierReturn {
  id           String   @id @default(cuid())
  returnNumber String   @unique
  stockId      String
  stock        Stock    @relation(fields: [stockId], references: [id])
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])

  quantityReturned Decimal  @db.Decimal(10, 2)
  reason           String
  returnDate       DateTime @default(now())
  refundAmount     Decimal  @db.Decimal(10, 2)
  refundMethod     String   // DEBT_OFFSET / CASH / BANK_TRANSFER / CREDIT_NOTE
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  creditNote SupplierCreditNote?

  @@index([stockId])
  @@index([supplierId])
  @@index([returnDate])
}

// ==========================================
// CREDIT NOTE SYSTEM
// ==========================================

model SupplierCreditNote {
  id               String   @id @default(cuid())
  creditNoteNumber String   @unique

  supplierId       String
  supplier         Supplier       @relation(fields: [supplierId], references: [id])
  supplierReturnId String         @unique
  supplierReturn   SupplierReturn @relation(fields: [supplierReturnId], references: [id])

  originalAmount  Decimal @db.Decimal(10, 2)
  remainingAmount Decimal @db.Decimal(10, 2)
  isFullyUsed     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages CreditNoteUsage[]

  @@index([supplierId])
  @@index([isFullyUsed])
  @@index([supplierId, isFullyUsed])
}

model CreditNoteUsage {
  id           String             @id @default(cuid())
  creditNoteId String
  creditNote   SupplierCreditNote @relation(fields: [creditNoteId], references: [id])
  stockId      String
  stock        Stock              @relation(fields: [stockId], references: [id])

  // Optional: when credit is used via a bill payment rather than per-stock
  billId String?

  amountUsed Decimal  @db.Decimal(10, 2)
  usedAt     DateTime @default(now())

  @@index([creditNoteId])
  @@index([stockId])
  @@index([billId])
}

// ==========================================
// SALES SYSTEM
// ==========================================

model Transaction {
  id            String    @id @default(cuid())
  receiptNumber String    @unique
  customerPhone String?
  customer      Customer? @relation(fields: [customerPhone], references: [phoneNumber])

  paymentMethod String

  subtotal            Decimal @db.Decimal(10, 2)
  totalItemDiscount   Decimal @default(0) @db.Decimal(10, 2)
  cartDiscount        Decimal @default(0) @db.Decimal(10, 2)
  pointsRedeemed      Int     @default(0)
  pointsRedeemedValue Decimal @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal @db.Decimal(10, 2)

  amountPaid  Decimal? @db.Decimal(10, 2)
  changeGiven Decimal? @db.Decimal(10, 2)

  pointsEarned Int      @default(0)
  saleDateTime DateTime @default(now())
  createdAt    DateTime @default(now())

  items        TransactionItem[]
  pointHistory CustomerPoint[]
  refunds      Refund[]

  @@index([receiptNumber])
  @@index([customerPhone])
  @@index([saleDateTime])
  @@index([paymentMethod])
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  stockId       String
  stock         Stock       @relation(fields: [stockId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  productName  String
  supplierName String

  quantity      Decimal @db.Decimal(10, 2)
  measuringUnit String
  pricePerUnit  Decimal @db.Decimal(10, 2)
  itemDiscount  Decimal @default(0) @db.Decimal(10, 2)
  lineTotal     Decimal @db.Decimal(10, 2)

  // NEW: Dual-unit selling — locked in at sale time
  soldInSplitUnit    Boolean   @default(false)
  splitUnitName      String?   // e.g. 'YARDS' — drives receipt display
  splitUnitsPerWhole Decimal?  @db.Decimal(10, 4)  // e.g. 10.0000 — drives refund restock math

  createdAt DateTime @default(now())

  refundItems RefundItem[]

  @@index([transactionId])
  @@index([stockId])
  @@index([productId])
}

model Refund {
  id                    String      @id @default(cuid())
  refundReceiptNumber   String      @unique
  originalTransactionId String
  originalTransaction   Transaction @relation(fields: [originalTransactionId], references: [id])
  customerPhone         String?
  customer              Customer?   @relation(fields: [customerPhone], references: [phoneNumber])

  refundDate        DateTime @default(now())
  refundMethod      String
  totalRefundAmount Decimal  @db.Decimal(10, 2)
  pointsDeducted    Int      @default(0)

  createdAt DateTime @default(now())

  items RefundItem[]

  @@index([originalTransactionId])
  @@index([refundDate])
}

model RefundItem {
  id                        String          @id @default(cuid())
  refundId                  String
  refund                    Refund          @relation(fields: [refundId], references: [id], onDelete: Cascade)
  originalTransactionItemId String
  originalTransactionItem   TransactionItem @relation(fields: [originalTransactionItemId], references: [id])
  stockId                   String

  productName      String
  quantityReturned Decimal @db.Decimal(10, 2)
  pricePerUnit     Decimal @db.Decimal(10, 2)
  refundAmount     Decimal @db.Decimal(10, 2)
  isRestocked      Boolean
  reason           String
  notes            String? @db.Text

  createdAt DateTime @default(now())

  @@index([refundId])
  @@index([originalTransactionItemId])
}

model Counter {
  id           String   @id
  currentValue Int      @default(0)
  updatedAt    DateTime @updatedAt
}
